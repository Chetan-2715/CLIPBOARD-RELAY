# Server Configuration
PORT=3000

# CORS Allowed Origins
# Add your local network IP (e.g. http://192.168.1.15:5173) to allow connecting from your phone!
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,*

# Upstash Redis Configuration (Serverless)
# Find these in your Upstash Console under the Redis database "REST API" section
UPSTASH_REDIS_REST_URL=https://your-database-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Cloudinary Storage Configuration
# Find these in your Cloudinary Dashboard under "API Keys" / Product Environment Credentials
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
